# ControlMe environment template

# Backend / database
DATABASE_URL="postgresql://<db_user>:<db_password>@localhost:5432/controlme?schema=public"
JWT_SECRET="<generate_a_real_secret>"
PORT=3001
ALLOWED_ORIGINS="http://localhost:3000"

# SMTP (optional, docker-compose defaults to local Mailpit)
SMTP_HOST=""
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ControlMe <noreply@controlme.app>"
APP_URL="http://localhost:3000"
EMAIL_REMINDER_CRON="0 * * * *"
EMAIL_REMINDER_TIMEZONE="UTC"
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_BASE_DELAY_MS=1000
EMAIL_RATE_LIMIT_PER_MINUTE=20
EMAIL_USER_DAILY_LIMIT=4
EMAIL_USER_MIN_INTERVAL_MINUTES=60

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Node
NODE_ENV="development"
