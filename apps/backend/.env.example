# ControlMe backend environment template

DATABASE_URL="postgresql://controlme:controlme_dev_password@localhost:5432/controlme?schema=public"
REDIS_URL="redis://:controlme_dev_redis_password@localhost:6379/0"
REDIS_CONNECT_TIMEOUT_MS="10000"
JWT_SECRET="<generate_a_real_secret>"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="<generate_a_second_real_secret>"
JWT_REFRESH_EXPIRES_IN="30d"
PORT="3001"
TRUST_PROXY="false"
ALLOWED_ORIGINS="http://localhost:3000"
APP_URL="http://localhost:3000"
APP_VERSION="0.1.0"
NODE_ENV="development"
INTERNAL_JOB_TOKEN="<set_for_manual_notification_trigger>"

# SMTP
SMTP_HOST=""
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ControlMe <noreply@controlme.app>"
EMAIL_REMINDER_CRON="0 * * * *"
EMAIL_REMINDER_TIMEZONE="UTC"
EMAIL_MAX_RETRIES="3"
EMAIL_RETRY_BASE_DELAY_MS="1000"
EMAIL_RATE_LIMIT_PER_MINUTE="20"
EMAIL_USER_DAILY_LIMIT="4"
EMAIL_USER_MIN_INTERVAL_MINUTES="60"

# Cache / queues / rate limiting / monitoring
CACHE_TTL_SECONDS="120"
THROTTLE_TTL_MS="60000"
THROTTLE_LIMIT="100"
THROTTLE_BLOCK_MS="300000"
AUTH_THROTTLE_TTL_MS="60000"
AUTH_THROTTLE_LIMIT="10"
AUTH_THROTTLE_BLOCK_MS="300000"
PASSWORD_RESET_THROTTLE_LIMIT="5"
PASSWORD_RESET_THROTTLE_BLOCK_MS="600000"
QUEUE_PREFIX="controlme"
QUEUE_CONCURRENCY="5"
METRICS_ENABLED="true"
LOG_FORMAT="pretty"
