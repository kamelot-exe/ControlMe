# ControlMe backend environment template

DATABASE_URL="postgresql://<db_user>:<db_password>@localhost:5432/controlme?schema=public"
JWT_SECRET="<generate_a_real_secret>"
PORT=3001
ALLOWED_ORIGINS="http://localhost:3000"
NODE_ENV="development"

# SMTP (optional, docker-compose defaults to local Mailpit)
SMTP_HOST=""
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ControlMe <noreply@controlme.app>"
APP_URL="http://localhost:3000"
EMAIL_REMINDER_CRON="0 8 * * *"
EMAIL_REMINDER_TIMEZONE="UTC"
