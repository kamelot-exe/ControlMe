// Prisma schema for ControlMe
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String    @id @default(uuid())
  email                    String    @unique
  passwordHash             String    @map("password_hash")
  currency                 String    @default("USD")
  budgetLimit              Float?    @map("budget_limit")
  passwordResetToken       String?   @unique @map("password_reset_token")
  passwordResetTokenExpiry DateTime? @map("password_reset_token_expiry")
  createdAt                DateTime  @default(now()) @map("created_at")

  subscriptions        Subscription[]
  notificationSettings NotificationSettings?
  notificationDeliveries NotificationDelivery[]

  @@map("users")
}

model Subscription {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String
  price          Decimal  @db.Decimal(10, 2)
  billingPeriod  String   @map("billing_period") // MONTHLY | YEARLY
  nextChargeDate DateTime @map("next_charge_date")
  category       String
  serviceGroup   String?  @map("service_group")
  needScore      Int      @default(70) @map("need_score")
  websiteUrl     String?  @map("website_url")
  notes          String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  usage SubscriptionUsage?
  notificationDeliveries NotificationDelivery[]

  @@map("subscriptions")
}

model SubscriptionUsage {
  id                 String    @id @default(uuid())
  subscriptionId     String    @unique @map("subscription_id")
  lastConfirmedUseAt DateTime? @map("last_confirmed_use_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_usage")
}

model NotificationSettings {
  id                    String  @id @default(uuid())
  userId                String  @unique @map("user_id")
  prechargeReminderDays Int     @default(1) @map("precharge_reminder_days")
  smartAlertsEnabled    Boolean @default(true) @map("smart_alerts_enabled")
  renewalEmailsEnabled  Boolean @default(true) @map("renewal_emails_enabled")
  unusedEmailsEnabled   Boolean @default(false) @map("unused_emails_enabled")
  weeklyDigestEnabled   Boolean @default(true) @map("weekly_digest_enabled")
  monthlyDigestEnabled  Boolean @default(true) @map("monthly_digest_enabled")
  weeklyDigestDay       Int     @default(1) @map("weekly_digest_day")
  monthlyDigestDay      Int     @default(1) @map("monthly_digest_day")
  digestTime            String? @map("digest_time")
  timeZone              String? @default("UTC") @map("time_zone")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model NotificationDelivery {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  subscriptionId String?   @map("subscription_id")
  type           String
  dedupeKey      String    @unique @map("dedupe_key")
  scheduledFor   DateTime? @map("scheduled_for")
  sentAt         DateTime? @map("sent_at")
  status         String
  attemptCount   Int       @default(0) @map("attempt_count")
  lastAttemptAt  DateTime? @map("last_attempt_at")
  lastError      String?   @map("last_error")
  payload        Json?
  createdAt      DateTime  @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([userId, type], map: "notification_delivery_user_type_idx")
  @@index([subscriptionId], map: "notification_delivery_subscription_idx")
  @@map("notification_delivery")
}

model ServiceCatalogEntry {
  id               String   @id @default(uuid())
  service          String
  group            String
  subcategory      String
  similarityGroup  String   @map("similarity_group")
  region           String
  country          String
  plan             String
  price            Decimal  @db.Decimal(12, 2)
  currency         String
  billingPeriod    String   @map("billing_period")
  website          String
  logoHint         String   @map("logo_hint")
  priority         String
  defaultNeedScore Int      @map("default_need_score")
  planRank         Int      @default(1) @map("plan_rank")
  isFamilyPlan     Boolean  @default(false) @map("is_family_plan")
  isStudentPlan    Boolean  @default(false) @map("is_student_plan")
  isBusinessPlan   Boolean  @default(false) @map("is_business_plan")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([service, country, plan, currency, billingPeriod], map: "service_catalog_unique_entry")
  @@index([service], map: "service_catalog_service_idx")
  @@index([similarityGroup], map: "service_catalog_similarity_group_idx")
  @@index([region, country], map: "service_catalog_region_country_idx")
  @@index([group], map: "service_catalog_group_idx")
  @@map("service_catalog_entries")
}
